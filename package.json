{
  "name": "mcp-typst-gost",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for generating GOST-compliant academic documents via Typst templates",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@modelcontextprotocol/sdk": "latest",
    "@openrouter/sdk": "^0.12.35",
    "eventemitter3": "^5.0.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.8.3"
  }
}
